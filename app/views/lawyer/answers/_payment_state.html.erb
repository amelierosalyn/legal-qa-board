<article>
  <p>
    <strong><%= answer.lawyer.name %></strong>
    answered on <%= answer.created_at.strftime("%d %B %Y at %H:%M") %> and proposed a fee of
    <strong><%= number_to_currency(answer.fee_in_pounds, unit: "£") %></strong>
  </p>

  <% if answer.paid? %>
    <%= simple_format(answer.response_text) %>
  <% else %>
    <p>Approve payment to view this answer.</p>

    <% if answer.payment_request.pending? %>
      <%= button_to "Approve payment",
            approve_payment_request_path(answer.payment_request),
            method: :patch %>
    <% end %>
  <% end %>
</article>