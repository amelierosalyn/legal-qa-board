<h1><%= @question.title %></h1>

<p>
  <strong>Asked by:</strong>
  <%= @question.user.name %> on <%= @question.created_at.strftime("%d %B %Y %H:%M") %>
</p>

<p>
  <strong>Category:</strong>
  <%= @question.category.titleize %>
</p>

<p>
  <%= simple_format(@question.body) %>
</p>

<h2>Submit paid advice</h2>

<%= form_with model: [:lawyer, @question, @answer], url: lawyer_question_answers_path(@question, as: "lawyer") do |form| %>
  <% if @answer.errors.any? %>
    <div>
      <h3><%= pluralize(@answer.errors.count, "error") %> prevented this answer from being saved:</h3>

      <ul>
        <% @answer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :response_text, "Advice" %><br>
    <%= form.text_area :response_text, rows: 8 %>
  </div>

  <div>
    <%= form.label :proposed_fee_pounds, "Fee (£)" %><br>
    <%= form.number_field :proposed_fee_pounds, min: 0.01, step: 0.01%>
  </div>

  <div>
    <%= form.submit "Submit answer" %>
  </div>
<% end %>

<h2>Existing responses</h2>

<%= turbo_frame_tag "question_answers" do %>
  <%= render "lawyer/questions/answers", question: @question %>
<% end %>
